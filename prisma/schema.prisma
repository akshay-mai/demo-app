generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
   url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @unique
  password    String
  gender      String?
  dateOfBirth String?
  phone       String?
  address     String?
  city        String?
  state       String?
  country     String?
  pincode     String?
  occupation  String?
  nationality String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
